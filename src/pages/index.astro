---
import Layout from "../layouts/Layout.astro";
---

<Layout title="TreeSproutHaven | Restoring Hope">
  <section class="hero">
    <img
      src="/hero-bg.png"
      alt="A young plant shoot emerging from the soil"
      class="hero-bg"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Restoring Hope.<br />Rebuilding Lives.</h1>
      <p>
        A sanctuary for new beginnings, providing community-based support for
        those navigating life's most difficult chapters.
      </p>
      <div class="hero-buttons">
        <a href="/about" class="btn btn-primary">Our Mission</a>
        <a href="/services" class="btn btn-outline">Explore Services</a>
      </div>
    </div>
  </section>

  <section class="section-about-teaser section--white">
    <div class="container">
      <div class="split-layout">
        <div class="split-image reveal-left">
          <img
            src="/community-gathering.jpg"
            alt="Community gathering"
            class="rounded-image"
          />
        </div>
        <div class="split-content reveal-right">
          <span class="eyebrow">Who We Are</span>
          <h2>A Foundation for Growth</h2>
          <p class="lead">
            TreeSproutHaven is a trauma-informed community organization
            dedicated to supporting at-risk individuals—particularly those who
            are marginalized by systemic barriers. We believe in the power of
            connection to heal and rebuild.
          </p>
          <div>
            <a href="/about" class="btn btn-outline-green">Read Our Story</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-services-highlight section--sand">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What We Offer</span>
        <h2>Holistic Support</h2>
      </div>
      <div class="services-grid">
        <div class="service-card reveal stagger-1">
          <i class="ph ph-shield-check"></i>
          <h3>Trauma-Informed Care</h3>
          <p>
            Prioritizing safety, trust, and empowerment in every interaction.
          </p>
        </div>
        <div class="service-card reveal stagger-2">
          <i class="ph ph-first-aid"></i>
          <h3>Addiction Recovery</h3>
          <p>
            Peer-led support circles and clinical wraparound case management.
          </p>
        </div>
        <div class="service-card reveal stagger-3">
          <i class="ph ph-house-line"></i>
          <h3>Transitional Housing</h3>
          <p>
            Safe, stable housing designed to foster dignity and ownership.
          </p>
        </div>
      </div>
      <div class="section-actions">
        <a href="/services" class="btn btn-outline-green">View All Services</a>
      </div>
    </div>
  </section>

  <section class="section-gallery section--white">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What We Do</span>
        <h2>Care in Practice</h2>
      </div>
      <div class="carousel home-carousel" id="home-carousel">
        <div class="carousel-track-container">
          <ul class="carousel-track">
            <li class="carousel-slide current-slide">
              <figure class="carousel-figure">
                <img src="/housing-indigenous.png" alt="Transitional housing interior" class="carousel-image rounded-image" />
                <figcaption class="carousel-caption">
                  <span class="eyebrow">Transitional Housing</span>
                  <h3>Safe, stable homes</h3>
                  <p>Furnished living spaces designed for dignity, privacy, and rest while participants rebuild.</p>
                </figcaption>
              </figure>
            </li>
            <li class="carousel-slide">
              <figure class="carousel-figure">
                <img src="/treesprout_wellness_healing.jpg" alt="Wellness and ceremony room" class="carousel-image rounded-image" />
                <figcaption class="carousel-caption">
                  <span class="eyebrow">Wellness & Healing</span>
                  <h3>Trauma-informed care</h3>
                  <p>Counseling, ceremony, and Elder-led healing grounded in Indigenous practice.</p>
                </figcaption>
              </figure>
            </li>
            <li class="carousel-slide">
              <figure class="carousel-figure">
                <img src="/treesprout_community_programs.jpg" alt="Community gathering" class="carousel-image rounded-image" />
                <figcaption class="carousel-caption">
                  <span class="eyebrow">Community Programs</span>
                  <h3>Peer support circles</h3>
                  <p>Group sessions and shared meals that rebuild connection and accountability.</p>
                </figcaption>
              </figure>
            </li>
            <li class="carousel-slide">
              <figure class="carousel-figure">
                <img src="/treesprout_cultural_programming.jpg" alt="Cultural programming" class="carousel-image rounded-image" />
                <figcaption class="carousel-caption">
                  <span class="eyebrow">Cultural Programming</span>
                  <h3>Reconnecting with culture</h3>
                  <p>Land-based activities, language, and traditions woven through everyday care.</p>
                </figcaption>
              </figure>
            </li>
            <li class="carousel-slide">
              <figure class="carousel-figure">
                <img src="/indigenous_youth_outdoor.jpg" alt="Indigenous youth in an outdoor program" class="carousel-image rounded-image" />
                <figcaption class="carousel-caption">
                  <span class="eyebrow">Youth Care</span>
                  <h3>Support for children and youths</h3>
                  <p>Land-based learning and structured routines that help young people grow in safety.</p>
                </figcaption>
              </figure>
            </li>
            <li class="carousel-slide">
              <figure class="carousel-figure">
                <img src="/indigenous_youth_art.jpg" alt="Indigenous youth in an art session" class="carousel-image rounded-image" />
                <figcaption class="carousel-caption">
                  <span class="eyebrow">Expressive Therapy</span>
                  <h3>Healing through creativity</h3>
                  <p>Art and cultural expression that give participants new ways to process and rebuild.</p>
                </figcaption>
              </figure>
            </li>
            <li class="carousel-slide">
              <figure class="carousel-figure">
                <img src="/indigenous_adults_circle.jpg" alt="Indigenous adults in a support circle" class="carousel-image rounded-image" />
                <figcaption class="carousel-caption">
                  <span class="eyebrow">Adult Care</span>
                  <h3>Support for adults</h3>
                  <p>Recovery circles and wraparound case management for adults rebuilding stability.</p>
                </figcaption>
              </figure>
            </li>
          </ul>
        </div>
        <button class="carousel-button carousel-button--left is-hidden" aria-label="Previous slide">
          <i class="ph ph-caret-left"></i>
        </button>
        <button class="carousel-button carousel-button--right" aria-label="Next slide">
          <i class="ph ph-caret-right"></i>
        </button>
        <div class="carousel-nav">
          <button class="carousel-indicator current-slide" aria-label="Slide 1"></button>
          <button class="carousel-indicator" aria-label="Slide 2"></button>
          <button class="carousel-indicator" aria-label="Slide 3"></button>
          <button class="carousel-indicator" aria-label="Slide 4"></button>
          <button class="carousel-indicator" aria-label="Slide 5"></button>
          <button class="carousel-indicator" aria-label="Slide 6"></button>
          <button class="carousel-indicator" aria-label="Slide 7"></button>
        </div>
      </div>
    </div>
  </section>

  <section class="section-cta section--evergreen">
    <div class="container">
      <div class="cta reveal">
        <h2>Ready to Find Support?</h2>
        <p>
          We are here to listen, support, and help you navigate your journey to
          recovery and reconnection.
        </p>
        <a href="/contact" class="btn btn-primary">Get in Touch</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const carousel = document.getElementById("home-carousel");
  if (carousel) {
    const track = carousel.querySelector<HTMLElement>(".carousel-track")!;
    const realSlides = Array.from(track.children) as HTMLElement[];
    const total = realSlides.length;
    const nextButton = carousel.querySelector<HTMLButtonElement>(".carousel-button--right")!;
    const prevButton = carousel.querySelector<HTMLButtonElement>(".carousel-button--left")!;
    const dotsNav = carousel.querySelector<HTMLElement>(".carousel-nav")!;
    const dots = Array.from(dotsNav.children) as HTMLElement[];

    // Clone the first slide and append it so the loop only ever moves forward.
    const clone = realSlides[0].cloneNode(true) as HTMLElement;
    clone.classList.remove("current-slide");
    track.appendChild(clone);
    const allSlides = Array.from(track.children) as HTMLElement[];

    // Slide transition (0.7s) plus the caption stagger needs to fully settle
    // before we reset, so the clone and the real first slide look identical.
    const SETTLE_MS = 1200;
    let current = 0;
    let snapTimer: ReturnType<typeof setTimeout> | undefined;

    // Jump from the clone back to the real first slide with every transition
    // suppressed. Both are identical and fully settled, so it is invisible.
    function snapBack() {
      if (current !== total) return;
      carousel.classList.add("is-snapping");
      setSlide(0);
      void track.offsetWidth;
      carousel.classList.remove("is-snapping");
    }

    const setSlide = (idx: number) => {
      current = idx;
      track.style.transform = `translateX(-${idx * 100}%)`;
      allSlides.forEach((s, i) => s.classList.toggle("current-slide", i === idx));
      const real = idx % total;
      dots.forEach((d, i) => d.classList.toggle("current-slide", i === real));
      prevButton.classList.toggle("is-hidden", idx === 0);
      if (snapTimer) clearTimeout(snapTimer);
      if (idx === total) snapTimer = setTimeout(snapBack, SETTLE_MS);
    };

    const AUTOPLAY_MS = 5000;
    let timer: ReturnType<typeof setInterval> | undefined;
    const advance = () => {
      if (current < total) setSlide(current + 1);
    };
    const startAutoplay = () => {
      stopAutoplay();
      timer = setInterval(advance, AUTOPLAY_MS);
    };
    const stopAutoplay = () => {
      if (timer) clearInterval(timer);
    };

    nextButton.addEventListener("click", () => {
      if (current < total) setSlide(current + 1);
      startAutoplay();
    });
    prevButton.addEventListener("click", () => {
      if (current > 0) setSlide(current - 1);
      startAutoplay();
    });
    dotsNav.addEventListener("click", (e) => {
      const dot = (e.target as HTMLElement).closest("button");
      if (!dot) return;
      setSlide(dots.findIndex((d) => d === dot));
      startAutoplay();
    });

    carousel.addEventListener("mouseenter", stopAutoplay);
    carousel.addEventListener("mouseleave", startAutoplay);
    startAutoplay();
  }
</script>
