---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About Us | TreeSproutHaven">
  <section class="page-header">
    <div class="container">
      <h1>Our Mission</h1>
      <p class="lead">Restoring Hope. Rebuilding Lives.</p>
    </div>
  </section>

  <section id="mission" class="section-mission">
    <div class="container mission-container">
      <div class="mission-image-wrapper reveal-right">
        <img
          src="/mission-indigenous.jpg"
          alt="Indigenous community gathering in a circle"
          class="mission-image"
        />
      </div>
      <div class="mission-text-card reveal stagger-2">
        <span class="eyebrow">Who We Are</span>
        <h2>A Foundation for Growth</h2>
        <p class="lead">
          TreeSproutHaven is a trauma-informed community organization dedicated
          to supporting at-risk individuals—particularly those who are
          marginalized by systemic barriers.
        </p>
        <p>
          We specialize in providing holistic, culturally grounded care with a
          focus on out-of-detention and diversion, family reunification, and
          transitional housing programs. Through harm reduction, addiction
          recovery, mediation services, and Indigenous-led cultural healing
          initiatives, TreeSproutHaven fosters long-term recovery,
          reconnection, and reintegration into community life.
        </p>
        <p>
          Our purpose is to create a resilient, culturally safe space for
          individuals recovering from trauma, addiction, incarceration, and
          displacement.
        </p>
        <a href="/contact" class="btn btn-primary">Join Our Community</a>
      </div>
    </div>
  </section>

  <section id="vision" class="section--sand">
    <div class="container">
      <div class="statement reveal">
        <span class="eyebrow">Our Vision</span>
        <h2>A Future of Belonging</h2>
        <p>
          We envision a world where every individual has the support, resources,
          and community connections needed to heal from trauma and thrive in
          their daily lives. We are building a legacy of hope for generations to
          come.
        </p>
      </div>
    </div>
  </section>

  <section id="values" class="section--white">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Our Core Values</span>
        <h2>What Guides Us</h2>
      </div>
      <div class="services-grid">
        <div class="service-card reveal stagger-1">
          <i class="ph ph-heartbeat"></i>
          <h3>Compassion</h3>
          <p>
            We approach every interaction with kindness, understanding, and a
            non-judgmental heart.
          </p>
        </div>
        <div class="service-card reveal stagger-2">
          <i class="ph ph-hand-palm"></i>
          <h3>Cultural Safety</h3>
          <p>
            We honor and respect the diverse identities, traditions, and lived
            experiences of our community.
          </p>
        </div>
        <div class="service-card reveal stagger-3">
          <i class="ph ph-users-four"></i>
          <h3>Community</h3>
          <p>
            We believe that healing happens in relationship with others. We are
            stronger together.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
